# Gemini API Key (用于图像分析)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Gemini analysis model (可选)
NEXT_PUBLIC_GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# Gemini image generation model (可选)
NEXT_PUBLIC_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Demo mode: true = mock image generation; false = real API generation
NEXT_PUBLIC_USE_MOCK=true
