# Gemini API Key (server-side only)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini analysis model (optional)
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# Gemini image generation model (optional)
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Gemini image fallback model when primary is overloaded (optional)
GEMINI_IMAGE_FALLBACK_MODEL=

# Allow flash fallback for peak hours (default false)
KV_IMAGE_FALLBACK_TO_FLASH=false
# Legacy alias (still supported): ALLOW_FLASH_FALLBACK=false

# Demo mode: true = mock image generation; false = real API generation
NEXT_PUBLIC_USE_MOCK=true
